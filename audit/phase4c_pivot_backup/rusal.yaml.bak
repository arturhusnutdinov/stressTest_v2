# Rusal — PDF Parser Adapter (v2)
# Language: EN (primary), RU (Phase 4c)

meta:
  company_id: rusal
  reporting_unit: mUSD
  decimal_separator: "."
  thousands_separator: ","
  negative_style: parens

sections:

  IS:
    page_triggers:
      - "Consolidated Statement of Income"
      - "Consolidated Statement of Comprehensive Income"
      - "Consolidated Statement of Profit or Loss"
      - "Consolidated Income Statement"
    page_anti_triggers:
      - "Table of Contents"
      - "Contents"
      - "Index"
    columns:
      metric_col: 0
      note_col: 3
      year_cols_from: 4
      expected_year_count: 2

    rows:
      revenue:
        patterns:
          - "^revenue"
          - "^totalrevenue"
      cogs:
        patterns:
          - "^costofsales"
          - "^costofgoodssold"
          - "^costofrevenue"
      gross_profit:
        patterns:
          - "^grossprofit"
      distribution_expenses:
        patterns:
          - "^distributionexpenses"
          - "^selling.*distribution"
      sga:
        patterns:
          - "^administrativeexpenses"
          - "^generalandadministrative"
      asset_impairment:
        patterns:
          - "^impairment.*non.?currentassets"
          - "^impairmentofproperty"
          - "^reversalofimpairment"
      earnings_from_investees:
        patterns:
          - "^shareof(profit|results).*associates"
          - "^shareof(profit|results).*joint"
      expected_credit_losses:
        patterns:
          - "^expectedcreditloss"
          - "^impairmentlossontrade"
      other_operating_expenses:
        patterns:
          - "^netotheroperating"
          - "^otheroperating"
          - "^other(losses|gains).*net"
      ebit:
        patterns:
          - "^resultsfromoperatingactivities"
          - "^operatingprofit"
          - "^profitfromoperations"
      interest_income:
        patterns:
          - "^financeincome"
          - "^interestincome"
      interest_expense:
        patterns:
          - "^finance(expense|costs)"
          - "^financeexpenses"
      ebt:
        patterns:
          - "^profit.*beforetax"
          - "^loss.*beforetax"
          - "^profitbeforetax"
      tax_expense:
        patterns:
          - "^incometaxexpense"
          - "^incometax"
          - "^taxation"
      net_income:
        patterns:
          - "^profitfortheyear"
          - "^lossfortheyear"
          - "^netprofitforthe"
          - "^\\(loss\\)/profitforthe"
      ebitda:
        patterns:
          - "^adjustedebitda"
          - "^ebitda"

    notes_only:
      - dep_ppe
      - amort_intangibles
      - total_da
      - current_tax
      - deferred_tax

  BS:
    page_triggers:
      - "Consolidated Statement of Financial Position"
      - "Consolidated Balance Sheet"
    page_anti_triggers:
      - "Table of Contents"
      - "Contents"
    section_anchors:
      - "Total assets"
      - "Total equity"
    section_markers:
      non_current_assets:
        - "non-currentassets"
      current_assets:
        - "currentassets"
      equity:
        - "equityandliabilities"
      non_current_liab:
        - "non-currentliabilities"
      current_liab:
        - "currentliabilities"
    rows:
      ppe_net:
        patterns:
          - "^property,?plantandequipment"
        sections: [non_current_assets]
      intangibles:
        patterns:
          - "^intangibleassets"
        sections: [non_current_assets]
      investments_in_associates:
        patterns:
          - "^interestsinassociatesandjoint"
        sections: [non_current_assets]
      dta:
        patterns:
          - "^deferredtaxassets"
        sections: [non_current_assets]
      other_nca:
        patterns:
          - "^othernon-currentassets"
        sections: [non_current_assets]
      total_nca:
        patterns:
          - "^totalnon-currentassets"
      inventory:
        patterns:
          - "^inventories"
        sections: [current_assets]
      accounts_receivable:
        patterns:
          - "^tradeandotherreceivables"
        sections: [current_assets]
      cash:
        patterns:
          - "^cashandcashequivalents"
        sections: [current_assets]
      total_ca:
        patterns:
          - "^totalcurrentassets"
      total_assets:
        patterns:
          - "^totalassets"
      share_capital:
        patterns:
          - "^sharecapital"
        sections: [equity]
      apic:
        patterns:
          - "^sharepremium"
        sections: [equity]
      retained_earnings:
        patterns:
          - "^retainedearnings"
        sections: [equity]
      total_equity:
        patterns:
          - "^totalequity"
      long_term_debt:
        patterns:
          - "^loansandborrowings"
        sections: [non_current_liab]
      dtl:
        patterns:
          - "^deferredtaxliabilities"
        sections: [non_current_liab]
      total_ncl:
        patterns:
          - "^totalnon-currentliabilities"
      short_term_debt:
        patterns:
          - "^loansandborrowings"
        sections: [current_liab]
      accounts_payable:
        patterns:
          - "^tradeandotherpayables"
        sections: [current_liab]
      total_cl:
        patterns:
          - "^totalcurrentliabilities"

      # ─── Phase 4b-ii-agg: direct rows ──────────────────────────
      aoci:
        patterns:
          - "^currencytranslationreserve"
        sections: [equity]
      nci:
        patterns:
          - "^otherreserves"
        sections: [equity]
      other_ca_tax:
        patterns:
          - "^currentincom.*taxreceivables"
        sections: [current_assets]
      taxes_payable:
        patterns:
          - "^othertaxpaya"
        sections: [current_liab]
      dividends_payable:
        patterns:
          - "^dividendspay"
        sections: [current_liab]

      # ─── Phase 4b-ii-agg: helper rows (prefix _) ───────────────
      _short_term_investments:
        patterns:
          - "^short-?terminv"
        sections: [current_assets]
      _prepayments_vat:
        patterns:
          - "^prepayments"
        sections: [current_assets]
      _dividends_receivable:
        patterns:
          - "^dividendsrece"
        sections: [current_assets]
      _derivative_assets_ca:
        patterns:
          - "^derivativefina.*assets"
        sections: [current_assets]
      _advances_received:
        patterns:
          - "^advancesrece"
        sections: [current_liab]
      _derivative_liab_cl:
        patterns:
          - "^derivativefina.*liabilities"
        sections: [current_liab]
      _provisions_cl:
        patterns:
          - "^provisions"
        sections: [current_liab]
      _provisions_ncl:
        patterns:
          - "^provisions"
        sections: [non_current_liab]
      _other_ncl_line:
        patterns:
          - "^othernon-currentliabilities"
        sections: [non_current_liab]

      # ─── Phase 4b-ii-agg: aggregates (combine_from) ────────────
      other_ca:
        combine_from:
          - _short_term_investments
          - _prepayments_vat
          - _dividends_receivable
          - _derivative_assets_ca
      other_cl:
        combine_from:
          - _advances_received
          - _derivative_liab_cl
          - _provisions_cl
      other_ncl:
        combine_from:
          - _provisions_ncl
          - _other_ncl_line

    notes_only:
      # Helper rows (internal, used by combine_from aggregates)
      - _short_term_investments
      - _prepayments_vat
      - _dividends_receivable
      - _derivative_assets_ca
      - _advances_received
      - _derivative_liab_cl
      - _provisions_cl
      - _provisions_ncl
      - _other_ncl_line
      # DB-incompatible (sign convention or no DB counterpart)
      - taxes_payable
      - dividends_payable
  CF:
    page_triggers:
      - "Consolidated Statement of Cash Flows"
      - "Consolidated Statements of Cash Flows"
      - "Consolidated Cash Flow Statement"
    page_anti_triggers:
      - "Table of Contents"
      - "Contents"
    section_anchors:
      - "Operating activities"
      - "Investing activities"
      - "Financing activities"
    section_markers:
      operating:
        - "Operating activities"
      investing:
        - "Investing activities"
      financing:
        - "Financing activities"
    rows:
      # ─── Operating activities ──────────────────────────────────
      cfo_net_income:
        patterns:
          - "^profitforthe(year|period)"
        sections: [operating]
      depreciation:
        patterns:
          - "^depreciation"
        sections: [operating]
      amortization:
        patterns:
          - "^amortisation"
          - "^amortization"
        sections: [operating]
      impairment_noncash:
        patterns:
          - "^impairmentofnon-?currentassets"
        sections: [operating]
      fx_noncash:
        patterns:
          - "^netforeignexchange"
          - "^foreignexchange"
        sections: [operating]
      interest_noncash:
        patterns:
          - "^interestexpense"
        sections: [operating]
      interest_income_noncash:
        patterns:
          - "^interestincome"
        sections: [operating]
      tax_noncash:
        patterns:
          - "^incometaxexpense"
        sections: [operating]
      share_associates_noncash:
        patterns:
          - "^shareof(profits?|results)ofassociates"
        sections: [operating]
      cfo_before_wc:
        patterns:
          # Values on 2nd row ("in working capital and provisions")
          - "^inworkingcapitalandprovision"
        sections: [operating]
      wc_inventory:
        patterns:
          - "\\(increase\\)/decreaseininventories"
          - "decreaseininventories"
          - "increaseininventories"
        sections: [operating]
      wc_receivables:
        patterns:
          - "\\(increase\\)/decreaseintradeandother"
          - "decreaseintradeandotherreceivables"
          - "increaseintrade"
        sections: [operating]
      wc_payables:
        patterns:
          # Values on 2nd row ("received") after "Increase/(decrease) in...payables and advances"
          - "^received"
        sections: [operating]
      wc_provisions:
        patterns:
          - "decreaseinprovisions"
          - "increaseinprovisions"
          - "\\(increase\\)/decreaseinprovisions"
        sections: [operating]
      cfo_before_tax:
        patterns:
          - "^cashgeneratedfromoperationsbeforeincometax"
          - "^cashgeneratedfromoperations"
        sections: [operating]
      cfo_income_tax_paid:
        patterns:
          - "^incometaxpaid"
        sections: [operating]
      cfo_total:
        patterns:
          - "^netcashgenerated.*operatingactivities"
          - "^netcashfromoperating"
          - "^netcashusedinoperating"
        sections: [operating]

      # ─── Investing activities ──────────────────────────────────
      proceeds_ppe_disposal:
        patterns:
          - "^proceedsfromdisposalofproperty"
        sections: [investing]
      interest_received:
        patterns:
          - "^interestreceived"
        sections: [investing]
      capex:
        patterns:
          - "^acquisitionofproperty"
          - "^purchaseofproperty"
        sections: [investing]
      acquisitions:
        patterns:
          - "^acquisitionofajointventure"
          - "^acquisitionofsubsidiaries"
        sections: [investing]
      dividends_from_associates:
        patterns:
          - "^dividendsfromassociates"
          - "^dividendsreceivedfromassociates"
        sections: [investing]
      capex_intangibles:
        patterns:
          - "^acquisitionofintangible"
        sections: [investing]
      cfi_other:
        patterns:
          - "^cashreceivedfrom"
          - "^cash(paidfor|receivedfrom).*otherinvestments"
        sections: [investing]
      cfi_total:
        patterns:
          - "^netcashgenerated.*investingactivities"
          - "^netcashfrominvesting"
          - "^netcashusedininvesting"
        sections: [investing]

      # ─── Financing activities ──────────────────────────────────
      cff_lt_debt_issuance:
        patterns:
          - "^proceedsfromborrowings"
          - "^proceedsfromloans"
        sections: [financing]
      cff_lt_debt_repayment:
        patterns:
          - "^repayment(s?)ofborrowings"
          - "^repayment(s?)ofloans"
        sections: [financing]
      refinancing_fees:
        patterns:
          - "^refinancingfees"
          - "^transactioncosts"
          - "^debtissuancecosts"
        sections: [financing]
      interest_paid:
        patterns:
          - "^interestpaid"
        sections: [financing]
      cff_total:
        patterns:
          - "^netcashgenerated.*financingactivities"
          - "^netcashfromfinancing"
          - "^netcashused.*financing"
        sections: [financing]

      # ─── Cash bridge (no section filter) ───────────────────────
      net_change_cash:
        patterns:
          - "^net(increase|decrease)incash"
          - "^netchangeincash"
      cash_opening:
        patterns:
          - "^cashandcashequivalentsatthebeginning"
          - "^cashatthebeginning"
      fx_effect_cash:
        patterns:
          - "^effectofexchangerate"
          - "^effectofforeignexchange"
      cash_closing:
        patterns:
          - "^cashandcashequivalentsattheend"
          - "^cashattheend"

    notes_only: []

  # ─── Notes ─────────────────────────────────────────────────────

  NOTE_16_INVENTORY:
    page_triggers:
      - "Raw materials and consumables"
    page_anti_triggers:
      - "Table of Contents"
    section_anchors:
      - "Work in progress"
      - "Finished goods"
    rows:
      inventory_raw_materials:
        patterns:
          - "^rawmaterialsandconsumables"
          - "^rawmaterials"
      inventory_wip:
        patterns:
          - "^workinprogress"
      inventory_fg:
        patterns:
          - "^finishedgoodsandgoodsheldforresale"
          - "^finishedgoods"
    notes_only: []

  NOTE_13_PPE:
    page_triggers:
      - "Property, plant and equipment and investment properties"
      - "Property, plant and equipment"
    page_anti_triggers:
      - "Table of Contents"
    section_anchors:
      - "Balance at 1 January"
      - "Depreciation charge"
    pivot_header_rows: 3
    pivot_label_col: 0
    pivot_data_col_start: 2
    pivot_blocks:
      cost:
        - "Cost"
        - "deemed cost"
      accum_dep:
        - "Accumulated depreciation"
        - "Accumulated amortisation"
    pivot_movements:
      opening:
        - "Balance at 1 January"
        - "at beginning of the year"
      additions:
        - "Additions"
      disposals:
        - "Disposals"
      transfers:
        - "Transfers"
      fx:
        - "Foreign currency translation"
      acquired_through_business:
        - "Acquired through business"
      depreciation_charge:
        - "Depreciation charge"
      impairment:
        - "Impairment loss"
        - "reversal of impairment"
      closing:
        - "Balance at 31 December"
        - "at end of the year"
    pivot_year_in_label: true

  NOTE_19_DEBT_LOANS:
    page_triggers:
      - "Terms and debt repayment schedule"
    page_anti_triggers:
      - "Table of Contents"
    instrument_classes:
      secured_bank_loan:
        - "Secured bank loans"
      unsecured_bank_loan:
        - "Unsecured bank loans"
      unsecured_company_loan:
        - "Unsecured company loans from related parties"
        - "Unsecured company loans"
    rate_types:
      variable:
        - "Variable"
      fixed:
        - "Fixed"
    skip_rows:
      - "^Total"
      - "^Interest payable"
      - "^bonds"
      - "^The nominal"
      - "^The Group"
      - "^USD million"
      - "^As at"
      - "^covenants"
      - "^facility"
      - "^shares"
      - "^plant"
    maturity_buckets_count: 7
    maturity_bucket_names:
      - total
      - yr1
      - yr2
      - yr3
      - yr4
      - yr5
      - yr6_plus
