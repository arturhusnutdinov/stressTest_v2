    "## 🔄 ШАГ 7.3: Обновление файлов Edgar для загрузки всей истории\n",
    "\n",
    "**Цель**: Обновить файлы Edgar (`us_steel_IS_long.csv` и `us_steel_all_long.csv`) с исправленными данными для 2024 года, чтобы затем перезагрузить всю историю через `load_edgar_to_data_mart.py`\n",
    "\n",
    "**Важно**: \n",
    "- Аналогично BS, мы обновляем файлы Edgar в директории `/Users/arturhusnutdinov/Documents/IT Development/Docker/EDGAR/out_2010_2024_10K/`\n",
    "- После обновления используем `load_edgar_to_data_mart.py` для загрузки всей истории IS из Edgar в БД\n",
    "- Это перезагрузит всю историю с правильными данными для 2024 года\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# === Обновление файлов Edgar для загрузки всей истории ===\n",
    "\n",
    "display(Markdown(\"### 🔄 Обновление файлов Edgar для загрузки всей истории\"))\n",
    "\n",
    "print(\"=\"*80)\n",
    "print(\"ОБНОВЛЕНИЕ ФАЙЛОВ EDGAR ДЛЯ ЗАГРУЗКИ ВСЕЙ ИСТОРИИ\")\n",
    "print(\"=\"*80)\n",
    "\n",
    "if 'corrected_canonical_2024' not in globals() or not corrected_canonical_2024:\n",
    "    print(\"❌ Исправленный canonical формат не создан. Запустите ШАГ 7.\")\n",
    "    print(\"   ШАГ 7 создаст переменную corrected_canonical_2024 с правильными значениями\")\n",
    "else:\n",
    "    # Путь к директории Edgar - автоматический поиск\n",
    "    import os\n",
    "    from pathlib import Path\n",
    "    \n",
    "    # Список возможных путей для поиска\n",
    "    possible_base_paths = [\n",
    "        \"/Users/arturhusnutdinov/Documents/IT Development/Docker/EDGAR\",\n",
    "        os.path.expanduser(\"~/Documents/IT Development/Docker/EDGAR\"),\n",
    "        Path.home() / \"Documents/IT Development/Docker/EDGAR\",\n",
    "    ]\n",
    "    \n",
    "    # Приоритетная директория (если существует)\n",
    "    preferred_dir_name = \"out_2010_2024_10K\"\n",
    "    \n",
    "    # Ищем директорию с файлами us_steel_IS_long.csv\n",
    "    edgar_dir = None\n",
    "    edgar_path_str = None\n",
    "    found_dirs = []  # Все найденные директории с нужными файлами\n",
    "    \n",
    "    for base_path in possible_base_paths:\n",
    "        base_path_obj = Path(base_path) if isinstance(base_path, str) else base_path\n",
    "        if not base_path_obj.exists() or not base_path_obj.is_dir():\n",
    "            continue\n",
    "        \n",
    "        # Ищем директории с out_* в названии\n",
    "        for item in base_path_obj.iterdir():\n",
    "            if item.is_dir() and item.name.startswith(\"out\"):\n",
    "                # Проверяем наличие нужных файлов\n",
    "                is_file = item / \"us_steel_IS_long.csv\"\n",
    "                all_file = item / \"us_steel_all_long.csv\"\n",
    "                if is_file.exists() and all_file.exists():\n",
    "                    found_dirs.append(item)\n",
    "                    # Приоритет: сначала ищем preferred_dir_name\n",
    "                    if item.name == preferred_dir_name:\n",
    "                        edgar_dir = item\n",
    "                        edgar_path_str = str(item)\n",
    "                        break\n",
    "        \n",
    "        # Если нашли приоритетную директорию, останавливаемся\n",
    "        if edgar_dir:\n",
    "            break\n",
    "    \n",
    "    # Если не нашли приоритетную, используем первую найденную\n",
    "    if edgar_dir is None and found_dirs:\n",
    "        edgar_dir = found_dirs[0]\n",
    "        edgar_path_str = str(found_dirs[0])\n",
    "        print(f\"⚠️ Приоритетная директория '{preferred_dir_name}' не найдена\")\n",
    "        print(f\"   Используется: {edgar_dir.name}\")\n",
    "    \n",
    "    if edgar_dir is None or edgar_path_str is None:\n",
    "        print(f\"❌ Директория Edgar не найдена\")\n",
    "        print(\"\\n💡 Проверенные базовые пути:\")\n",
    "        for base_path in possible_base_paths:\n",
    "            base_path_obj = Path(base_path) if isinstance(base_path, str) else base_path\n",
    "            exists = base_path_obj.exists() if hasattr(base_path_obj, 'exists') else os.path.exists(str(base_path_obj))\n",
    "            print(f\"   • {base_path_obj} - {'✅ существует' if exists else '❌ не существует'}\")\n",
    "        \n",
    "        print(\"\\n📋 Ищем директории с out_*:\")\n",
    "        for base_path in possible_base_paths:\n",
    "            base_path_obj = Path(base_path) if isinstance(base_path, str) else base_path\n",
    "            if base_path_obj.exists() and base_path_obj.is_dir():\n",
    "                for item in base_path_obj.iterdir():\n",
    "                    if item.is_dir() and item.name.startswith(\"out\"):\n",
    "                        is_file = item / \"us_steel_IS_long.csv\"\n",
    "                        print(f\"   • {item.name} - IS файл: {'✅' if is_file.exists() else '❌'}\")\n",
    "        \n",
    "        print(\"\\n💡 Укажите правильный путь вручную или проверьте наличие файлов us_steel_IS_long.csv\")\n",
    "    else:\n",
    "        print(f\"✅ Найдена директория Edgar: {edgar_dir}\")\n",
    "        print(f\"   Путь: {edgar_path_str}\")\n",
    "        \n",
    "        # Файлы для обновления\n",
    "        is_long_file = edgar_dir / \"us_steel_IS_long.csv\"\n",
    "        all_long_file = edgar_dir / \"us_steel_all_long.csv\"\n",
    "        \n",
    "        # Маппинг canonical метрик на метрики Edgar (как они называются в файлах Edgar)\n",
    "        # Это нужно для обновления файлов Edgar с правильными названиями метрик\n",
    "        canonical_to_edgar_metric = {\n",
    "            'revenue': 'revenue',\n",
    "            'cogs': 'cogs',\n",
    "            'gross_profit': 'gross_profit',\n",
    "            'sga': 'sga',\n",
    "            'rnd': 'rnd',\n",
    "            'ebitda': 'ebitda',\n",
    "            'depreciation_owned': 'depreciation_owned',\n",
    "            'depreciation_rou': 'depreciation_rou',\n",
    "            'amortization': 'amortization',\n",
    "            'total_da': 'depreciation_amortization',  # В Edgar это называется depreciation_amortization\n",
    "            'gain_loss_on_disposal': 'gain_loss_on_disposal',\n",
    "            'ebit': 'ebit',\n",
    "            'interest_income': 'interest_income',\n",
    "            'interest_expense': 'interest_expense',\n",
    "            'lease_interest': 'lease_interest',\n",
    "            'other_income': 'other_income',\n",
    "            'other_expenses': 'other_expenses',\n",
    "            'ebt': 'ebt',\n",
    "            'tax_expense': 'tax_expense',\n",
    "            'net_income': 'net_income',\n",
    "            'eps_basic': 'eps_basic',\n",
    "            'eps_diluted': 'eps_diluted',\n",
    "        }\n",
    "        \n",
    "        updated_count_is = 0\n",
    "        updated_count_all = 0\n",
    "        \n",
    "        # 1. Обновляем us_steel_IS_long.csv\n",
    "        if is_long_file.exists():\n",
    "            print(f\"\\n📝 Обновление {is_long_file.name}...\")\n",
    "            df_is = pd.read_csv(is_long_file)\n",
    "            \n",
    "            # Обновляем данные для 2024 года\n",
    "            for canonical_metric, value in corrected_canonical_2024.items():\n",
    "                edgar_metric = canonical_to_edgar_metric.get(canonical_metric, canonical_metric)\n",
    "                \n",
    "                # Находим строку для обновления (statement='IS', metric=edgar_metric, year=2024)\n",
    "                mask = (df_is['statement'] == 'IS') & (df_is['metric'] == edgar_metric) & (df_is['year'] == 2024)\n",
    "                \n",
    "                if mask.any():\n",
    "                    old_value = df_is.loc[mask, 'value'].iloc[0]\n",
    "                    df_is.loc[mask, 'value'] = value\n",
    "                    if abs(old_value - value) > 1e-6:\n",
    "                        print(f\"   ✅ Обновлено {edgar_metric}: ${old_value:,.0f} → ${value:,.0f}\")\n",
    "                        updated_count_is += 1\n",
    "                else:\n",
    "                    # Добавляем новую строку\n",
    "                    new_row = {\n",
    "                        'company': 'US Steel',\n",
    "                        'statement': 'IS',\n",
    "                        'metric': edgar_metric,\n",
    "                        'year': 2024,\n",
    "                        'value': value,\n",
    "                        'source': 'xbrl:facts'\n",
    "                    }\n",
    "                    df_is = pd.concat([df_is, pd.DataFrame([new_row])], ignore_index=True)\n",
    "                    print(f\"   🆕 Добавлено {edgar_metric}: ${value:,.0f}\")\n",
    "                    updated_count_is += 1\n",
    "            \n",
    "            # Сохраняем обновленный файл\n",
    "            df_is.to_csv(is_long_file, index=False)\n",
    "            print(f\"\\n✅ {is_long_file.name} обновлен: {updated_count_is} метрик\")\n",
    "        else:\n",
    "            print(f\"\\n⚠️ Файл не найден: {is_long_file.name}\")\n",
    "        \n",
    "        # 2. Обновляем us_steel_all_long.csv\n",
    "        if all_long_file.exists():\n",
    "            print(f\"\\n📝 Обновление {all_long_file.name}...\")\n",
    "            df_all = pd.read_csv(all_long_file)\n",
    "            \n",
    "            # Обновляем данные для 2024 года (только IS)\n",
    "            for canonical_metric, value in corrected_canonical_2024.items():\n",
    "                edgar_metric = canonical_to_edgar_metric.get(canonical_metric, canonical_metric)\n",
    "                \n",
    "                # Находим строку для обновления (statement='IS', metric=edgar_metric, year=2024)\n",
    "                mask = (df_all['statement'] == 'IS') & (df_all['metric'] == edgar_metric) & (df_all['year'] == 2024)\n",
    "                \n",
    "                if mask.any():\n",
    "                    old_value = df_all.loc[mask, 'value'].iloc[0]\n",
    "                    df_all.loc[mask, 'value'] = value\n",
    "                    if abs(old_value - value) > 1e-6:\n",
    "                        print(f\"   ✅ Обновлено {edgar_metric}: ${old_value:,.0f} → ${value:,.0f}\")\n",
    "                        updated_count_all += 1\n",
    "                else:\n",
    "                    # Добавляем новую строку\n",
    "                    new_row = {\n",
    "                        'company': 'US Steel',\n",
    "                        'statement': 'IS',\n",
    "                        'metric': edgar_metric,\n",
    "                        'year': 2024,\n",
    "                        'value': value,\n",
    "                        'source': 'xbrl:facts'\n",
    "                    }\n",
    "                    df_all = pd.concat([df_all, pd.DataFrame([new_row])], ignore_index=True)\n",
    "                    print(f\"   🆕 Добавлено {edgar_metric}: ${value:,.0f}\")\n",
    "                    updated_count_all += 1\n",
    "            \n",
    "            # Сохраняем обновленный файл\n",
    "            df_all.to_csv(all_long_file, index=False)\n",
    "            print(f\"\\n✅ {all_long_file.name} обновлен: {updated_count_all} метрик\")\n",
    "        else:\n",
    "            print(f\"\\n⚠️ Файл не найден: {all_long_file.name}\")\n",
    "        \n",
    "        print(f\"\\n\" + \"=\"*80)\n",
