    "                            'Новое значение': f\"${new_val:,.0f}\",\n",
    "                            'Разница': f\"${new_val - (old_val if pd.notna(old_val) else 0):,.0f}\"\n",
    "                        })\n",
    "                        print(f\"  {metric}: ${old_val:,.0f} -> ${new_val:,.0f}\")\n",
    "                        updates_count += 1\n",
