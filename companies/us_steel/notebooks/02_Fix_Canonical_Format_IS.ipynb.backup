    "        print(f\"=\"*80)\n",
    "        print(f\"\\n📋 СВОДКА:\")\n",
    "        print(f\"   • us_steel_IS_long.csv: {updated_count_is} метрик обновлено ✅\")\n",
    "        print(f\"   • us_steel_all_long.csv: {updated_count_all} метрик обновлено ✅\")\n",
    "        print(f\"\\n📋 ЦЕПОЧКА ДАННЫХ:\")\n",
