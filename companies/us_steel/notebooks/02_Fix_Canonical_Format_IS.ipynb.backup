    "\n",
    "# Загружаем CANONICAL данные (после маппинга)\n",
    "is_canonical = mart.get_history_income_statement(canonical=True)\n",
    "\n",
    "print(\"\\n\" + \"=\"*80)\n",
    "print(\"📊 СРАВНЕНИЕ: RAW vs CANONICAL (2024)\")\n",
    "print(\"=\"*80)\n",
